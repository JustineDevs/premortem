{
  "name": "@premortem/gitlab-sync",
  "private": true,
  "type": "module",
  "main": "./dist/services/gitlab-sync/src/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/services/gitlab-sync/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "node ../../scripts/fix-esm-imports.mjs dist",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@premortem/db": "workspace:*",
    "@premortem/domain": "workspace:*",
    "@premortem/integrations": "workspace:*",
    "@premortem/orchestrator": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
