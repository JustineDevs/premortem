{
  "name": "@premortem/agent-builder",
  "private": true,
  "type": "module",
  "main": "./dist/services/agent-builder/src/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/services/agent-builder/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "node ../../scripts/fix-esm-imports.mjs dist",
    "start": "node dist/services/agent-builder/src/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@google/adk": "^1.1.0",
    "@premortem/domain": "workspace:*",
    "@premortem/integrations": "workspace:*",
    "@premortem/observability": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
