{
  "name": "premortem",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "node ./scripts/dev/run-local-stack.mjs",
    "dev:ngrok-stripe": "node ./scripts/dev/run-ngrok-stripe.mjs",
    "dev:turbo": "turbo dev",
    "build": "turbo build",
    "build:pages": "node ./scripts/cloudflare/run-pages-build.mjs",
    "build:pages:raw": "turbo build --filter=@premortem/web... --concurrency=1",
    "build:pages:cloudflare": "node ./scripts/cloudflare/run-pages-build.mjs",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "scan:deadcode": "knip --production --no-exit-code",
    "scan:secrets": "node ./scripts/devtools/trufflehog.mjs",
    "devtools:scan": "pnpm run scan:deadcode && pnpm run scan:secrets",
    "eval:prompts": "pnpm --filter @premortem/agent-kit build && pnpm --filter @premortem/llm build && pnpm --filter @premortem/observability build && pnpm --filter @premortem/evals build && node ./scripts/patch-promptfoo-opentelemetry.mjs && promptfoo validate config -c packages/evals/promptfoo/promptfooconfig.yaml && promptfoo validate config -c packages/evals/promptfoo/promptfooconfig.validator.yaml && promptfoo validate config -c packages/evals/promptfoo/promptfooconfig.floor.yaml && promptfoo eval -c packages/evals/promptfoo/promptfooconfig.yaml -o packages/evals/promptfoo/results.finding-synthesizer.json --max-concurrency 1 && promptfoo eval -c packages/evals/promptfoo/promptfooconfig.validator.yaml -o packages/evals/promptfoo/results.issue-validator.json --max-concurrency 1 && promptfoo eval -c packages/evals/promptfoo/promptfooconfig.floor.yaml -o packages/evals/promptfoo/results.specialist-floor.json --max-concurrency 1 && node ./scripts/verify-promptfoo-threshold.mjs packages/evals/promptfoo/results.finding-synthesizer.json 0.95 && node ./scripts/verify-promptfoo-threshold.mjs packages/evals/promptfoo/results.issue-validator.json 0.95 && node ./scripts/verify-promptfoo-threshold.mjs packages/evals/promptfoo/results.specialist-floor.json 1",
    "db:generate": "bash ./scripts/prisma-env.sh generate",
    "db:migrate": "bash ./scripts/prisma-env.sh db push --skip-generate",
    "db:status": "bash ./scripts/prisma-env.sh db pull --print",
    "db:studio": "bash ./scripts/prisma-env.sh studio",
    "db:reset-audits": "npx tsx --tsconfig tsconfig.base.json ./scripts/dev/reset-local-audit-data.mjs",
    "db:reassign-smoke": "npx tsx --tsconfig tsconfig.base.json ./scripts/dev/reassign-smoke-workspace.mjs",
    "db:reset-billing": "npx tsx --tsconfig tsconfig.base.json ./scripts/dev/reset-local-billing.mjs",
    "stripe:sync-catalog": "node ./apps/web/scripts/stripe-sync-catalog.mjs",
    "audit:local": "npx tsx --tsconfig tsconfig.base.json ./scripts/dev/run-local-audit.mjs",
    "audit:gitlab": "npx tsx --tsconfig tsconfig.base.json ./scripts/gitlab/run-duo-audit.mjs",
    "smoke:audit-flow": "bash ./scripts/smoke/run-audit-flow.sh",
    "smoke:onboarding-e2e": "PREMORTEM_SMOKE_USE_FIXTURE=1 npx tsx --tsconfig tsconfig.base.json ./scripts/smoke/verify-onboarding-e2e.mjs",
    "smoke:full-app-stress": "PREMORTEM_SMOKE_USE_FIXTURE=1 npx tsx --tsconfig tsconfig.base.json ./scripts/smoke/verify-full-app-stress.mjs",
    "smoke:production-readiness": "PREMORTEM_PRODUCTION_MODE=1 npx tsx --tsconfig tsconfig.base.json ./scripts/smoke/verify-production-readiness.mjs",
    "smoke:verify-gitlab-publish": "npx tsx --tsconfig tsconfig.base.json ./scripts/smoke/debug-gitlab-publish-token.mjs",
    "smoke:fixture": "PREMORTEM_SMOKE_USE_FIXTURE=1 npx tsx --tsconfig tsconfig.base.json ./scripts/smoke/verify-production-readiness.mjs",
    "smoke:local": "bash ./scripts/smoke/run-local-stack.sh",
    "smoke:product-truth": "npx tsx --tsconfig tsconfig.base.json ./scripts/smoke/verify-product-truth.mjs",
    "smoke:security-fixes": "npx tsx --tsconfig tsconfig.base.json ./scripts/smoke/verify-security-fixes.ts",
    "smoke:hackathon": "npx tsx --tsconfig tsconfig.base.json ./scripts/smoke/verify-hackathon-readiness.mjs",
    "smoke:arize": "pnpm run smoke:hackathon",
    "devpost:submission": "node ./scripts/release/print-devpost-submission.mjs",
    "smoke:agent-builder-runtime": "pnpm --filter @premortem/agent-builder build && npx tsx --tsconfig tsconfig.base.json ./scripts/smoke/verify-agent-builder-runtime.mjs",
    "phoenix:bootstrap": "pnpm --filter @premortem/observability build && npx tsx --tsconfig tsconfig.base.json ./scripts/phoenix/bootstrap-platform.mjs",
    "verify:env": "npx tsx --tsconfig tsconfig.base.json ./scripts/smoke/verify-env-utilization.mjs",
    "verify:evidence-snippets": "npx tsx --tsconfig tsconfig.base.json ./scripts/verify-persisted-evidence-snippets.mjs",
    "lint:deadcode": "knip --production",
    "docker:up": "node ./scripts/docker/ensure-services.mjs",
    "docker:up:sudo": "PREMORTEM_DOCKER_SUDO=1 node ./scripts/docker/ensure-services.mjs",
    "docker:down": "docker compose down",
    "docker:status": "node ./scripts/docker/verify-services.mjs",
    "docker:test-neo4j": "npx tsx --tsconfig tsconfig.base.json ./scripts/docker/test-neo4j.mjs",
    "premortem": "node ./packages/cli/dist/index.js",
    "prepare": "node ./scripts/setup-husky.mjs",
    "doctor": "npx react-doctor@latest"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "husky": "^9.1.7",
    "knip": "^6.16.1",
    "prisma": "^5.20.0",
    "promptfoo": "^0.121.17",
    "tsx": "^4.20.0",
    "turbo": "^2.0.12",
    "typescript": "^5.6.3",
    "wrangler": "^4.100.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1",
      "uuid": "13.0.2",
      "@tootallnate/once": "2.0.1",
      "tar": "7.5.16",
      "postcss": "8.5.15",
      "dompurify": "3.4.10",
      "ws": "8.21.0",
      "@opentelemetry/core": "1.30.1",
      "@opentelemetry/context-async-hooks": "1.30.1",
      "@opentelemetry/resources": "1.30.1",
      "@opentelemetry/sdk-trace-base": "1.30.1",
      "@opentelemetry/sdk-trace-node": "1.30.1",
      "form-data@2.5.5": "2.5.6",
      "form-data@4.0.4": "4.0.6"
    }
  }
}
