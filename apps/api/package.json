{
  "name": "@premortem/api",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/local-server.ts",
    "dev:worker": "wrangler dev",
    "deploy": "wrangler deploy",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "bash ../../scripts/smoke/run-audit-flow.sh",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@premortem/domain": "workspace:*",
    "@premortem/db": "workspace:*",
    "@premortem/gitlab-sync": "workspace:*",
    "@premortem/orchestrator": "workspace:*",
    "@premortem/storage": "workspace:*",
    "@premortem/workflow": "workspace:*",
    "@premortem/observability": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "wrangler": "^3.86.1"
  }
}
