{
  "name": "@premortem/web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "lint": "tsc -p tsconfig.typecheck.json --noEmit",
    "predeploy": "pnpm --dir ../.. exec turbo build --filter=@premortem/domain --filter=@premortem/db --filter=@premortem/llm --filter=@premortem/orchestrator --filter=@premortem/storage --concurrency=1",
    "prepreview": "pnpm --dir ../.. exec turbo build --filter=@premortem/domain --filter=@premortem/db --filter=@premortem/llm --filter=@premortem/orchestrator --filter=@premortem/storage --concurrency=1",
    "preview": "opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion && opennextjs-cloudflare deploy",
    "start": "next start",
    "test": "npx tsx --tsconfig ../../tsconfig.base.json ../../scripts/smoke/run-local-stack.mjs",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "@premortem/db": "workspace:*",
    "@premortem/domain": "workspace:*",
    "@premortem/llm": "workspace:*",
    "@premortem/orchestrator": "workspace:*",
    "@premortem/storage": "workspace:*",
    "@radix-ui/react-slot": "^1.2.5",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.0",
    "@tanstack/react-query": "^5.101.0",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "elkjs": "^0.11.1",
    "geist": "^1.7.2",
    "lucide-react": "^1.17.0",
    "next": "14.2.35",
    "posthog-js": "^1.383.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^24.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.3"
  }
}
