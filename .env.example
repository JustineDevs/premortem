# Copy to .env.local and fill in values.

# --- App ---
# Production web: https://premortem.jstn.site | API: https://api.jstn.site
CORS_ORIGIN=https://premortem.jstn.site
NEXT_PUBLIC_APP_URL=
# PREMORTEM_SITE_URL=https://premortem.jstn.site
PREMORTEM_WEB_PORT=13000
PREMORTEM_API_PORT=18787
PREMORTEM_API_BASE_URL=http://127.0.0.1:18787
# Production: PREMORTEM_API_BASE_URL=https://api.jstn.site

# --- Webhooks (register URLs in Stripe/GitLab dashboards) ---
# Stripe: https://premortem.jstn.site/api/webhooks/stripe (secret: STRIPE_WEBHOOK_SECRET under Billing)
# GitLab Issue events: https://premortem.jstn.site/api/webhooks/gitlab (secret: GITLAB_WEBHOOK_SECRET under GitLab)
# Slack incoming webhooks or Nango-managed Slack API access
# SLACK_SIGNING_SECRET=
# NANGO_BASE_URL=http://localhost:3003
# NANGO_SECRET_KEY=
# NANGO_WEBHOOK_SIGNING_KEY=

# --- Database (Supabase Postgres) ---
# Runtime: transaction pooler :6543 + pgbouncer=true
PREMORTEM_DB_CONNECTION_LIMIT=5
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require&connection_limit=5
# Migrations: session pooler :5432 on the same host
DIRECT_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require

# --- Supabase Auth & Storage ---
# Web auth and BFF routes accept either the public NEXT_PUBLIC_* names or the server-side SUPABASE_* fallback names.
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=premortem-artifacts

# --- Cloudflare Turnstile (auth bot protection) ---
# Production: set both keys. Cloudflare test keys from docs work for local development.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Test keys:
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# --- LLM (Gemini is used when GEMINI_API_KEY is set) ---
GEMINI_API_KEY=
LLM_MODEL=gemini-3-flash-preview

# --- GitLab ---
GITLAB_BASE_URL=https://gitlab.com
GITLAB_EXTERNAL_PROJECT_ID=jstn-studio/meta-architect
# Personal Access Token with `api` scope for ingest + publish (not Cursor MCP read tokens).
# Optional override when GITLAB_TOKEN is read-only: GITLAB_SMOKE_PUBLISH_TOKEN=
GITLAB_TOKEN=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
# GitLab Issue webhook secret (X-Gitlab-Token); auto-registers hook on publish when set
GITLAB_WEBHOOK_SECRET=
# GitLab app redirect URI: {NEXT_PUBLIC_APP_URL}/api/integrations/callback/gitlab (use 127.0.0.1, not localhost, if that is your app URL)

# --- Orbit / GitLab Knowledge Graph ---
# Set to 1 to enrich audit runs with Orbit graph context when glab orbit remote is available.
ORBIT_ENABLED=0

# --- Neo4j graph store (pnpm run docker:up) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password12345

# --- Observability ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Arize Phoenix (OpenInference tracing + runtime MCP introspection)
PHOENIX_PROJECT_NAME=premortem
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com
PHOENIX_MCP_BASE_URL=https://app.phoenix.arize.com/s/your-space
PHOENIX_API_KEY=
# Set to 1 to run LLM-as-a-judge audit quality evals after completed audits (requires GEMINI_API_KEY)
PHOENIX_LLM_EVAL=0
# Set to 1 to append completed audit missions to the premortem-audit-missions Phoenix dataset
PHOENIX_SYNC_DATASETS=0
# Set to 1 when running scripts/phoenix/bootstrap-platform.mjs to register the LLM judge prompt
PHOENIX_SYNC_PROMPTS=0

# --- Billing (Stripe test mode) ---
# Dashboard webhook URL: https://premortem.jstn.site/api/webhooks/stripe
# sk_test_* keys: plan changes in /app Settings apply locally without Checkout.
# To exercise Checkout in test mode, set a test business name once at:
# https://dashboard.stripe.com/test/settings/account
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_TEAM_ANNUAL=

# --- Cloudflare (optional) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# --- Local dev toggles (optional) ---
# With DATABASE_URL + GITLAB_TOKEN + LLM + Supabase keys, `pnpm run dev` uses real auth
# (Supabase user.id as profileId) and real GitLab ingest. Do not set PREMORTEM_AUTH_DISABLED
# unless you are running smoke scripts (PREMORTEM_SMOKE_USE_FIXTURE=1).
# PREMORTEM_AUTH_DISABLED=1
# PREMORTEM_PRODUCTION_MODE=1
# PREMORTEM_SKIP_DOCKER=1
# PREMORTEM_DOCKER_SUDO=1
# NEO4J_DISABLED=1
# PREMORTEM_RECONCILE_DRY_RUN=1
# PREMORTEM_PUBLISH_DRY_RUN=1  # fixture/smoke only; omit for real GitLab issue create in local dev
# PREMORTEM_INGEST_LOCAL=1
# PREMORTEM_GITLAB_MCP=0

# Offline Postgres via docker-compose (instead of Supabase URLs above):
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/premortem
# DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:5432/premortem
