# Copy to .env.local and fill in values.

# --- App ---
CORS_ORIGIN=https://premortem.jstn.site
NEXT_PUBLIC_APP_URL=
PREMORTEM_WEB_PORT=13000
PREMORTEM_API_PORT=18787
PREMORTEM_API_BASE_URL=http://127.0.0.1:18787

# --- Database (Supabase Postgres) ---
# Runtime: transaction pooler :6543 + pgbouncer=true
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require&connection_limit=1
# Migrations: session pooler :5432 on the same host
DIRECT_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require

# --- Supabase Auth & Storage ---
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=premortem-artifacts

# --- LLM (Gemini is used when GEMINI_API_KEY is set) ---
GEMINI_API_KEY=
LLM_MODEL=gemini-3-flash-preview
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_MODEL=

# --- GitLab ---
GITLAB_BASE_URL=https://gitlab.com
GITLAB_EXTERNAL_PROJECT_ID=jstn-studio/meta-architect
# Personal Access Token with `api` scope for ingest + publish (not Cursor MCP read tokens).
# Optional override when GITLAB_TOKEN is read-only: GITLAB_SMOKE_PUBLISH_TOKEN=
GITLAB_TOKEN=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# --- Neo4j graph store (pnpm run docker:up) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password12345

# --- Observability ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Arize Phoenix (OpenInference tracing + runtime MCP introspection)
PHOENIX_PROJECT_NAME=premortem
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com
PHOENIX_MCP_BASE_URL=https://app.phoenix.arize.com/s/your-space
PHOENIX_API_KEY=

# --- Billing (Stripe test mode) ---
# sk_test_* keys: plan changes in /app Settings apply locally without Checkout.
# To exercise Checkout in test mode, set a test business name once at:
# https://dashboard.stripe.com/test/settings/account
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_TEAM_ANNUAL=

# --- Cloudflare (optional) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# --- Local dev toggles (optional) ---
# With DATABASE_URL + GITLAB_TOKEN + LLM + Supabase keys, `pnpm run dev` uses real auth
# (Supabase user.id as profileId) and real GitLab ingest. Do not set PREMORTEM_AUTH_DISABLED
# unless you are running smoke scripts (PREMORTEM_SMOKE_USE_FIXTURE=1).
# PREMORTEM_AUTH_DISABLED=1
# PREMORTEM_PRODUCTION_MODE=1
# PREMORTEM_SKIP_DOCKER=1
# PREMORTEM_DOCKER_SUDO=1
# NEO4J_DISABLED=1
# PREMORTEM_RECONCILE_DRY_RUN=1
# PREMORTEM_PUBLISH_DRY_RUN=1
# PREMORTEM_INGEST_LOCAL=1
# PREMORTEM_GITLAB_MCP=0

# Offline Postgres via docker-compose (instead of Supabase URLs above):
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/premortem
# DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:5432/premortem
