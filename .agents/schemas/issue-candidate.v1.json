{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://premortem.jstn.site/schemas/issue-candidate.v1.json",
  "title": "Premortem Issue Candidate v1",
  "type": "object",
  "required": ["id", "run_id", "title", "body", "source_finding_ids", "review_state", "version", "publish_target"],
  "properties": {
    "id": { "type": "string" },
    "run_id": { "type": "string" },
    "cluster_id": { "type": "string" },
    "title": { "type": "string" },
    "body": { "type": "string" },
    "source_finding_ids": { "type": "array", "items": { "type": "string" } },
    "review_state": { "enum": ["pending", "approved", "rejected", "edited"] },
    "version": { "type": "integer", "minimum": 1 },
    "publish_target": { "type": "string" }
  },
  "additionalProperties": true
}
