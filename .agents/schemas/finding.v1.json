{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://premortem.jstn.site/schemas/finding.v1.json",
  "title": "Premortem Finding v1",
  "type": "object",
  "required": ["id", "run_id", "specialist", "title", "summary", "severity", "confidence", "scope", "evidence", "status"],
  "properties": {
    "id": { "type": "string" },
    "run_id": { "type": "string" },
    "specialist": { "type": "string" },
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "severity": { "enum": ["low", "medium", "high", "critical"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "scope": {
      "type": "object",
      "properties": {
        "repo": { "type": "string" },
        "branch": { "type": "string" },
        "paths": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "pointer"],
        "properties": {
          "type": { "type": "string" },
          "pointer": { "type": "string" }
        }
      }
    },
    "reasoning": {
      "type": "object",
      "properties": {
        "hypothesis": { "type": "string" },
        "why_it_matters": { "type": "string" }
      }
    },
    "status": { "type": "string" }
  },
  "additionalProperties": true
}
